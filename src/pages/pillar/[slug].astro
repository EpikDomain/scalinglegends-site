---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const PILLARS: Record<string, { name: string; tagline: string; description: string; icon: string; keywords: string[] }> = {
  'market-intelligence': {
    name: 'Market Intelligence',
    tagline: 'Daily data. Weekly edge.',
    description: 'Daily market reports, economic indicators, and trend analysis for construction contractors who want to see around corners before competitors do.',
    icon: '📊',
    keywords: ['construction market intelligence', 'construction market report', 'construction industry news', 'construction trends 2026'],
  },
  'business-growth': {
    name: 'Business Growth',
    tagline: 'From $1M to $50M.',
    description: 'Scaling playbooks, cash flow systems, M&A strategies, and operational frameworks from contractors who built real companies.',
    icon: '📈',
    keywords: ['scaling construction business', 'construction business growth', 'construction company management', 'contractor growth strategies'],
  },
  'technology': {
    name: 'Technology & Innovation',
    tagline: 'Build smarter. Not harder.',
    description: 'AI tools, autonomous equipment, construction software, and emerging tech that gives forward-thinking contractors an unfair advantage.',
    icon: '⚡',
    keywords: ['construction technology', 'AI construction', 'construction software', 'construction automation 2026'],
  },
  'workforce': {
    name: 'Workforce & Safety',
    tagline: 'Your crew is your company.',
    description: 'Labor strategies, OSHA compliance, training programs, and workforce development for contractors fighting the 500K worker gap.',
    icon: '🦺',
    keywords: ['construction workforce', 'OSHA compliance', 'construction safety', 'construction labor shortage'],
  },
  'policy': {
    name: 'Policy & Regulation',
    tagline: 'Rules change. You adapt.',
    description: 'Tariff impacts, licensing requirements, government contracts, infrastructure funding, and compliance guides for contractors navigating a shifting regulatory landscape.',
    icon: '⚖️',
    keywords: ['construction regulations', 'construction tariffs', 'contractor licensing', 'construction policy 2026'],
  },
};

export function getStaticPaths() {
  return [
    { params: { slug: 'market-intelligence' } },
    { params: { slug: 'business-growth' } },
    { params: { slug: 'technology' } },
    { params: { slug: 'workforce' } },
    { params: { slug: 'policy' } },
  ];
}

const { slug } = Astro.params;
const pillar = PILLARS[slug as string];

if (!pillar) {
  return Astro.redirect('/404');
}

const now = new Date();
const allArticles = await getCollection('articles', ({ data }) => data.published !== false && data.pillar === slug && new Date(data.date) <= now);
const articles = allArticles.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const pillarKeys = Object.keys(PILLARS);

const breadcrumbs = [
  { name: "Home", url: "https://scalinglegends.com/" },
  { name: pillar.name, url: `https://scalinglegends.com/pillar/${slug}` },
];
---

<Base
  title={`${pillar.name} - Construction ${pillar.name} for Contractors`}
  description={pillar.description}
  keywords={pillar.keywords}
  breadcrumbs={breadcrumbs}
>
  <!-- Pillar Hero -->
  <section class="relative px-8 overflow-hidden" style="padding-top: 6rem; padding-bottom: 4rem;">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[600px] rounded-full opacity-20 pointer-events-none" style="background: radial-gradient(circle, rgba(204,255,0,0.15) 0%, transparent 70%);"></div>

    <div class="relative z-10 mx-auto">
      <!-- Breadcrumb -->
      <nav aria-label="Breadcrumb" class="mb-8 flex items-center gap-2 text-sm">
        <a href="/" class="text-[#888888] hover:text-[#CCFF00] transition-colors no-underline">Home</a>
        <span class="text-[#444444]">/</span>
        <span class="text-[#999999]">{pillar.name}</span>
      </nav>

      <div class="max-w-3xl">
        <div class="inline-flex items-center justify-center px-5 py-2.5 border border-[#CCFF00]/40 bg-[#CCFF00]/5 backdrop-blur-sm rounded-lg mb-6" style="font-size: 11px; font-weight: 700; letter-spacing: 0.12em;">
          <span class="text-[#CCFF00] uppercase">{pillar.name}</span>
        </div>

        <h1 class="text-[#EAEAEA] uppercase mb-4" style="font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 900; letter-spacing: -0.04em; line-height: 0.95;">
          {pillar.name}<span class="inline-block relative w-3 h-3 ml-2" style="vertical-align: baseline;"><span class="absolute inset-0 bg-[#CCFF00]"></span><span class="absolute inset-0 bg-gradient-to-br from-[#E0FF4D] via-[#CCFF00] to-[#9FCC00]" style="clip-path: polygon(0 0, 100% 0, 85% 15%, 15% 15%)"></span><span class="absolute inset-0 bg-gradient-to-br from-[#CCFF00] to-[#7A9900]" style="clip-path: polygon(100% 0, 100% 100%, 85% 85%, 85% 15%)"></span></span>
        </h1>

        <p class="text-[#CCFF00] mb-4" style="font-size: 1.125rem; font-weight: 600;">{pillar.tagline}</p>

        <p class="text-[#A8A8A8] mb-6" style="font-size: 1.0625rem; line-height: 1.7;">
          {pillar.description}
        </p>

        <div class="text-[#888888]" style="font-size: 0.875rem; font-weight: 600;">
          {articles.length} article{articles.length !== 1 ? 's' : ''}
        </div>
      </div>
    </div>
  </section>

  <!-- Pillar Nav (horizontal) -->
  <section class="px-8 pb-8">
    <div class="mx-auto">
      <div class="flex flex-wrap gap-2">
        {pillarKeys.map((key) => (
          <a
            href={`/pillar/${key}`}
            class:list={[
              "px-4 py-2 rounded-lg text-sm font-semibold transition-all duration-300 no-underline",
              key === slug
                ? "bg-[#CCFF00]/10 text-[#CCFF00] border border-[#CCFF00]/30"
                : "text-[#888888] border border-[#2A2A2A] hover:text-[#EAEAEA] hover:border-[#444444]"
            ]}
          >
            {PILLARS[key].name}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Articles Grid -->
  <section class="py-12 px-8 bg-gradient-to-b from-[#0D0D0D] to-[#000000]">
    <div class="mx-auto">
      {articles.length === 0 ? (
        <div class="text-center py-20">
          <p class="text-[#888888]" style="font-size: 1.125rem;">No articles in this pillar yet.</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
          {articles.map((article) => (
            <article class="group bg-gradient-to-b from-[#161616] to-[#121212] border border-[#222222] rounded-2xl overflow-hidden cursor-pointer transition-all duration-500 hover:border-[#CCFF00] hover:shadow-[0_8px_40px_rgba(204,255,0,0.12)] hover:-translate-y-2">
              {article.data.image && (
                <a href={`/article/${article.id}/`} class="block">
                  <div class="relative h-[180px] overflow-hidden flex items-center justify-center bg-[#0D0D0D]">
                    <img src={article.data.image} alt={article.data.title} class="max-w-full max-h-full object-contain transition-transform duration-700 group-hover:scale-110" loading="lazy" width="400" height="180" />
                    <div class="absolute inset-0 bg-gradient-to-t from-[#0D0D0D] via-transparent to-transparent opacity-60"></div>
                    <div class="absolute inset-0 bg-[#0D0D0D]/70 backdrop-blur-sm opacity-0 group-hover:opacity-100 transition-all duration-500 flex items-center justify-center">
                      <div class="flex items-center gap-3 text-[#CCFF00]" style="font-size: 0.875rem; font-weight: 600;">
                        {article.data.audioUrl ? (
                          <>
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                            <span>Listen Now</span>
                          </>
                        ) : (
                          <>
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                              <polyline points="14 2 14 8 20 8"/>
                            </svg>
                            <span>Read Article</span>
                          </>
                        )}
                      </div>
                    </div>
                  </div>
                </a>
              )}
              <div class="p-7 flex flex-col gap-4">
                <div class="flex items-center gap-3 text-[#999999]" style="font-size: 12px; font-weight: 500;">
                  <span>{new Date(article.data.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
                  <span class="w-1 h-1 bg-[#333333] rounded-full"></span>
                  {article.data.readTime && <span>{article.data.readTime}</span>}
                  {article.data.audioUrl && (
                    <>
                      <span class="w-1 h-1 bg-[#333333] rounded-full"></span>
                      <span class="text-[#CCFF00]">Podcast</span>
                    </>
                  )}
                </div>
                <h3 class="text-[#EAEAEA] group-hover:text-[#CCFF00] transition-colors duration-300" style="font-weight: 700; font-size: 1.25rem; line-height: 1.3;">
                  <a href={`/article/${article.id}/`} class="text-inherit no-underline">{article.data.title}</a>
                </h3>
                <p class="text-[#888888] line-clamp-2" style="font-size: 0.9375rem; line-height: 1.6;">
                  {article.data.description}
                </p>
                <div class="mt-2 flex items-center gap-2 text-[#999999] group-hover:text-[#CCFF00] group-hover:gap-3 transition-all duration-300" style="font-size: 0.875rem; font-weight: 600;">
                  <span>{article.data.audioUrl ? 'Listen' : 'Read More'}</span>
                  <svg width="14" height="14" viewBox="0 0 16 16" fill="none" class="transition-transform duration-300 group-hover:translate-x-1"><path d="M6 3L11 8L6 13" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
              </div>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- Other Pillars CTA -->
  <section class="py-16 px-8">
    <div class="mx-auto">
      <h2 class="text-[#EAEAEA] uppercase mb-8" style="font-weight: 900; font-size: 1.5rem; letter-spacing: -0.02em;">
        Explore More Pillars<span class="inline-block relative w-2 h-2 ml-1.5" style="vertical-align: baseline;"><span class="absolute inset-0 bg-[#CCFF00]"></span><span class="absolute inset-0 bg-gradient-to-br from-[#E0FF4D] via-[#CCFF00] to-[#9FCC00]" style="clip-path: polygon(0 0, 100% 0, 85% 15%, 15% 15%)"></span><span class="absolute inset-0 bg-gradient-to-br from-[#CCFF00] to-[#7A9900]" style="clip-path: polygon(100% 0, 100% 100%, 85% 85%, 85% 15%)"></span></span>
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {pillarKeys.filter(k => k !== slug).map((key) => (
          <a href={`/pillar/${key}`} class="group block bg-[#161616] border border-[#222222] rounded-xl p-6 hover:border-[#CCFF00] hover:shadow-[0_0_20px_rgba(204,255,0,0.1)] transition-all duration-300 no-underline">
            <div class="text-2xl mb-3">{PILLARS[key].icon}</div>
            <h3 class="text-[#EAEAEA] group-hover:text-[#CCFF00] transition-colors mb-2" style="font-weight: 700; font-size: 1rem;">{PILLARS[key].name}</h3>
            <p class="text-[#888888]" style="font-size: 0.8125rem; line-height: 1.5;">{PILLARS[key].tagline}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>

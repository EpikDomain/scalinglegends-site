---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const allArticles = await getCollection('articles', ({ data }) => data.published !== false);
const articles = allArticles.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const latestEpisode = articles.find(a => a.data.audioUrl && a.data.audioUrl.length > 0);
const episodes = articles.filter(a => a.data.audioUrl && a.data.audioUrl.length > 0).slice(0, 3);
const hasEpisodes = episodes.length > 0;
const featuredArticles = articles.slice(0, 8);
---

<Base
  title="Scaling Legends"
  description="Construction Industry Growth Stories. Data-driven podcast and intelligence for contractors scaling from $1M to $50M."
>
  <!-- Hero -->
  <section class="relative px-8 overflow-hidden" style="padding-top: 8rem; padding-bottom: 8rem;">
    <!-- Radial glow -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[800px] rounded-full opacity-30 pointer-events-none" style="background: radial-gradient(circle, rgba(204,255,0,0.15) 0%, transparent 70%);"></div>

    <div class="relative z-10 max-w-[1600px] mx-auto text-center flex flex-col items-center gap-8">
      <h1 class="uppercase max-w-4xl" style="font-size: clamp(2.5rem, 8vw, 5rem); font-weight: 900; letter-spacing: -0.04em; line-height: 0.95;">
        <span class="text-[#EAEAEA]">SCALING </span><span class="text-[#CCFF00] inline-block" style="text-shadow: 0 0 40px rgba(204,255,0,0.3);">LEGENDS<span class="inline-block relative w-3.5 h-3.5 ml-2" style="vertical-align: baseline;"><span class="absolute inset-0 bg-[#CCFF00]"></span><span class="absolute inset-0 bg-gradient-to-br from-[#E0FF4D] via-[#CCFF00] to-[#9FCC00]" style="clip-path: polygon(0 0, 100% 0, 85% 15%, 15% 15%)"></span><span class="absolute inset-0 bg-gradient-to-br from-[#CCFF00] to-[#7A9900]" style="clip-path: polygon(100% 0, 100% 100%, 85% 85%, 85% 15%)"></span></span></span>
      </h1>

      <div class="inline-flex items-center justify-center px-5 py-2.5 border border-[#CCFF00]/40 bg-[#CCFF00]/5 backdrop-blur-sm rounded-lg" style="font-size: 11px; font-weight: 700; letter-spacing: 0.12em;">
        <span class="text-[#CCFF00] uppercase">Construction Intelligence</span>
      </div>

      <p class="text-[#A8A8A8] max-w-3xl mx-auto" style="font-size: clamp(1rem, 2vw, 1.25rem); line-height: 1.6; font-weight: 400;">
        Data-driven podcast and market intelligence for construction business owners ready to scale.
      </p>

      <div class="flex flex-wrap items-center justify-center gap-4 mt-4">
        {latestEpisode ? (
          <a href={`/article/${latestEpisode.id}`} class="group relative px-8 py-4 bg-[#CCFF00] text-[#0D0D0D] rounded-lg font-semibold text-sm uppercase tracking-wider overflow-hidden transition-all duration-300 hover:shadow-[0_0_30px_rgba(204,255,0,0.4)] no-underline">
            Latest Episode
          </a>
        ) : (
          <a href="#articles" class="group relative px-8 py-4 bg-[#CCFF00] text-[#0D0D0D] rounded-lg font-semibold text-sm uppercase tracking-wider overflow-hidden transition-all duration-300 hover:shadow-[0_0_30px_rgba(204,255,0,0.4)] no-underline">
            Latest Episode
          </a>
        )}
        <a href="#articles" class="px-8 py-4 border border-[#2A2A2A] text-[#EAEAEA] rounded-lg font-semibold text-sm uppercase tracking-wider hover:border-[#CCFF00]/50 hover:bg-[#CCFF00]/5 transition-all duration-300 no-underline">
          Browse Articles
        </a>
      </div>
    </div>
  </section>

  <!-- Featured Episodes (only show if we have episodes) -->
  {hasEpisodes && (
    <section class="py-24 px-8 bg-[#0D0D0D]">
      <div class="max-w-[1600px] mx-auto">
        <div class="mb-12 max-w-2xl">
          <div class="inline-flex items-center gap-2 px-4 py-2 border border-[#2A2A2A] bg-[#161616] rounded-full mb-6" style="font-size: 11px; font-weight: 700; letter-spacing: 0.12em;">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#CCFF00" stroke-width="2">
              <path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/>
              <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
              <line x1="12" x2="12" y1="19" y2="22"/>
            </svg>
            <span class="text-[#CCFF00] uppercase">Podcast</span>
          </div>
          <h2 class="text-[#EAEAEA] uppercase mb-3" style="font-weight: 900; font-size: clamp(2rem, 4vw, 3rem); letter-spacing: -0.03em; line-height: 1.1;">
            Featured Episodes<span class="inline-block relative w-2 h-2 ml-1.5" style="vertical-align: baseline;"><span class="absolute inset-0 bg-[#CCFF00]"></span><span class="absolute inset-0 bg-gradient-to-br from-[#E0FF4D] via-[#CCFF00] to-[#9FCC00]" style="clip-path: polygon(0 0, 100% 0, 85% 15%, 15% 15%)"></span><span class="absolute inset-0 bg-gradient-to-br from-[#CCFF00] to-[#7A9900]" style="clip-path: polygon(100% 0, 100% 100%, 85% 85%, 85% 15%)"></span></span>
          </h2>
          <p class="text-[#999999]" style="font-size: 0.9375rem; line-height: 1.6;">
            Construction business intelligence from industry leaders
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 2xl:grid-cols-4 gap-8 mb-12">
          {episodes.map((ep) => (
            <div class="group bg-[#161616] border border-[#2A2A2A] rounded-xl overflow-hidden hover:border-[#CCFF00] hover:shadow-[0_0_30px_rgba(204,255,0,0.15)] transition-all duration-300">
              {ep.data.image && (
                <a href={`/article/${ep.id}`} class="block">
                  <div class="h-[180px] overflow-hidden flex items-center justify-center bg-[#0D0D0D]">
                    <img src={ep.data.image} alt={ep.data.title} class="max-w-full max-h-full object-contain group-hover:scale-105 transition-transform duration-500" loading="lazy" width="320" height="180" />
                  </div>
                </a>
              )}
              <div class="p-6">
                <div class="flex items-center gap-2 text-[#999999] mb-3" style="font-size: 12px; font-weight: 500;">
                  {ep.data.episode && <span>EP {ep.data.episode}</span>}
                  {ep.data.episode && <span class="w-1 h-1 bg-[#333333] rounded-full"></span>}
                  {ep.data.readTime && <span>{ep.data.readTime}</span>}
                </div>
                <h3 class="text-[#EAEAEA] mb-3 group-hover:text-[#CCFF00] transition-colors" style="font-weight: 700; font-size: 1.125rem; line-height: 1.4;">
                  <a href={`/article/${ep.id}`} class="text-inherit no-underline">{ep.data.title}</a>
                </h3>
                <p class="text-[#888888] mb-4 line-clamp-2" style="font-size: 0.875rem; line-height: 1.6;">
                  {ep.data.description}
                </p>
                <a href={`/article/${ep.id}`} class="flex items-center gap-2 text-[#CCFF00] group-hover:gap-3 transition-all no-underline" style="font-size: 0.875rem; font-weight: 600;">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                  <span>Listen Now</span>
                </a>
              </div>
            </div>
          ))}
        </div>

        <div class="text-center">
          <a href="/podcast" class="group px-8 py-4 border border-[#2A2A2A] text-[#EAEAEA] rounded-lg font-semibold text-sm uppercase tracking-wider hover:border-[#CCFF00]/50 hover:bg-[#CCFF00]/5 transition-all duration-300 inline-flex items-center gap-2 no-underline">
            <span>View All Episodes</span>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="group-hover:translate-x-1 transition-transform"><path d="M6 3L11 8L6 13" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- Articles -->
  <section class="py-24 px-8 bg-gradient-to-b from-[#0D0D0D] to-[#000000]" id="articles">
    <div class="max-w-[1600px] mx-auto">
      <div class="mb-12 max-w-2xl">
        <div class="inline-flex items-center gap-2 px-4 py-2 border border-[#2A2A2A] bg-[#161616] rounded-full mb-6" style="font-size: 11px; font-weight: 700; letter-spacing: 0.12em;">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#888888" stroke-width="2">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
          </svg>
          <span class="text-[#888888] uppercase">Articles & Insights</span>
        </div>
        <h2 class="text-[#EAEAEA] uppercase mb-3" style="font-weight: 900; font-size: clamp(2rem, 4vw, 3rem); letter-spacing: -0.03em; line-height: 1.1;">
          Latest Articles<span class="inline-block relative w-2 h-2 ml-1.5" style="vertical-align: baseline;"><span class="absolute inset-0 bg-[#CCFF00]"></span><span class="absolute inset-0 bg-gradient-to-br from-[#E0FF4D] via-[#CCFF00] to-[#9FCC00]" style="clip-path: polygon(0 0, 100% 0, 85% 15%, 15% 15%)"></span><span class="absolute inset-0 bg-gradient-to-br from-[#CCFF00] to-[#7A9900]" style="clip-path: polygon(100% 0, 100% 100%, 85% 85%, 85% 15%)"></span></span>
        </h2>
        <p class="text-[#999999]" style="font-size: 0.9375rem; line-height: 1.6;">
          Expert analysis and actionable insights for construction business leaders
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 2xl:grid-cols-4 gap-8">
        {featuredArticles.map((article) => (
          <article class="group bg-gradient-to-b from-[#161616] to-[#121212] border border-[#222222] rounded-2xl overflow-hidden cursor-pointer transition-all duration-500 hover:border-[#CCFF00] hover:shadow-[0_8px_40px_rgba(204,255,0,0.12)] hover:-translate-y-2">
            {article.data.image && (
              <a href={`/article/${article.id}`} class="block">
                <div class="relative h-[180px] overflow-hidden flex items-center justify-center bg-[#0D0D0D]">
                  <img src={article.data.image} alt={article.data.title} class="max-w-full max-h-full object-contain transition-transform duration-700 group-hover:scale-110" loading="lazy" width="400" height="180" />
                  <!-- Subtle bottom gradient only -->
                  <div class="absolute inset-0 bg-gradient-to-t from-[#0D0D0D] via-transparent to-transparent opacity-60"></div>
                  <!-- Hover overlay -->
                  <div class="absolute inset-0 bg-[#0D0D0D]/70 backdrop-blur-sm opacity-0 group-hover:opacity-100 transition-all duration-500 flex items-center justify-center">
                    <div class="flex items-center gap-3 text-[#CCFF00]" style="font-size: 0.875rem; font-weight: 600;">
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                        <polyline points="14 2 14 8 20 8"/>
                      </svg>
                      <span>Read Article</span>
                    </div>
                  </div>
                </div>
              </a>
            )}
            <div class="p-7 flex flex-col gap-4">
              <div class="flex items-center gap-3 text-[#999999]" style="font-size: 12px; font-weight: 500;">
                <span>{new Date(article.data.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
                <span class="w-1 h-1 bg-[#333333] rounded-full"></span>
                {article.data.readTime && <span>{article.data.readTime}</span>}
              </div>
              <h3 class="text-[#EAEAEA] group-hover:text-[#CCFF00] transition-colors duration-300" style="font-weight: 700; font-size: 1.25rem; line-height: 1.3;">
                <a href={`/article/${article.id}`} class="text-inherit no-underline">{article.data.title}</a>
              </h3>
              <p class="text-[#888888] line-clamp-2" style="font-size: 0.9375rem; line-height: 1.6;">
                {article.data.description}
              </p>
              <div class="mt-2 flex items-center gap-2 text-[#999999] group-hover:text-[#CCFF00] group-hover:gap-3 transition-all duration-300" style="font-size: 0.875rem; font-weight: 600;">
                <span>Read More</span>
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" class="transition-transform duration-300 group-hover:translate-x-1"><path d="M6 3L11 8L6 13" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</Base>

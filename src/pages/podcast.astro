---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const now = new Date();
const allArticles = await getCollection('articles', ({ data }) => data.published !== false && new Date(data.date) <= now);
const articles = allArticles.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const episodes = articles.filter(a => a.data.audioUrl && a.data.audioUrl.length > 0);
const featuredEpisode = episodes[0];
const otherEpisodes = episodes.slice(1);
const recentArticles = articles.filter(a => !a.data.audioUrl).slice(0, 6);
---

<Base
  title="Scaling Legends Podcast - Construction Industry Intelligence"
  description="Listen to Scaling Legends - Construction industry growth stories, market intelligence, and strategies for contractors scaling their business from $1M to $50M."
  breadcrumbs={[
    { name: "Home", url: "https://scalinglegends.com/" },
    { name: "Podcast", url: "https://scalinglegends.com/podcast" },
  ]}
>
  <div class="py-16 px-8">
    <div class="max-w-[1600px] mx-auto">
      <a
        href="/"
        class="mb-8 text-[#CCFF00] hover:text-[#E0FF4D] transition-colors inline-flex items-center gap-2 no-underline"
        style="font-weight: 500;"
      >
        <span>&larr;</span> Back to Home
      </a>

      <!-- Page Header -->
      <div class="mb-12 text-center">
        <div
          class="inline-flex items-center justify-center px-4 py-2 border border-[#CCFF00] bg-transparent rounded-md mb-6"
          style="font-size: 12px; font-weight: 700; letter-spacing: 0.08em;"
        >
          <span class="text-[#CCFF00] uppercase">PODCAST</span>
        </div>
        <h1
          class="text-[#EAEAEA] uppercase mb-4"
          style="font-weight: 900; font-size: 3rem; letter-spacing: -0.03em; line-height: 1.1;"
        >
          ALL EPISODES<span class="inline-block relative w-2 h-2 ml-1.5" style="vertical-align: baseline;"><span class="absolute inset-0 bg-[#CCFF00]"></span><span class="absolute inset-0 bg-gradient-to-br from-[#E0FF4D] via-[#CCFF00] to-[#9FCC00]" style="clip-path: polygon(0 0, 100% 0, 85% 15%, 15% 15%)"></span><span class="absolute inset-0 bg-gradient-to-br from-[#CCFF00] to-[#7A9900]" style="clip-path: polygon(100% 0, 100% 100%, 85% 85%, 85% 15%)"></span></span>
        </h1>
        <p class="text-[#888888] max-w-2xl mx-auto" style="font-size: 1.125rem; line-height: 1.7;">
          Weekly insights on scaling construction businesses through data, strategy, and operational excellence.
        </p>
      </div>

      <!-- Featured Episode -->
      {featuredEpisode && (
        <a href={`/article/${featuredEpisode.id}`} class="block no-underline">
          <div class="bg-[#161616] border border-[#2A2A2A] rounded-[10px] overflow-hidden mb-12 hover:border-[#CCFF00] transition-all duration-300 cursor-pointer">
            <div class="flex flex-col md:flex-row gap-0">
              {featuredEpisode.data.image && (
                <div class="h-[240px] md:h-auto md:w-[280px] overflow-hidden flex items-center justify-center bg-[#0D0D0D] p-6 flex-shrink-0">
                  <img src={featuredEpisode.data.image} alt={featuredEpisode.data.title} class="max-w-[220px] h-auto object-contain mx-auto rounded-lg" width="220" height="220" />
                </div>
              )}
              <div class="p-8 md:p-10 flex flex-col justify-center flex-1">
                <div
                  class="inline-flex items-center justify-start px-3 py-1 bg-[#CCFF00] text-[#0D0D0D] rounded-md mb-4 w-fit"
                  style="font-size: 11px; font-weight: 700; letter-spacing: 0.08em;"
                >
                  FEATURED EPISODE
                </div>
                <div class="flex items-center gap-2 text-[#888888] mb-4" style="font-size: 14px;">
                  {featuredEpisode.data.episode && <span>Episode {featuredEpisode.data.episode}</span>}
                  <span>&bull;</span>
                  <span>{new Date(featuredEpisode.data.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
                  {featuredEpisode.data.readTime && (
                    <>
                      <span>&bull;</span>
                      <span>{featuredEpisode.data.readTime}</span>
                    </>
                  )}
                </div>
                <h2
                  class="text-[#EAEAEA] mb-4"
                  style="font-weight: 800; font-size: 1.75rem; line-height: 1.3;"
                >
                  {featuredEpisode.data.title}
                </h2>
                <p
                  class="text-[#888888] mb-6"
                  style="font-size: 1rem; line-height: 1.7;"
                >
                  {featuredEpisode.data.description}
                </p>
                <span
                  class="px-6 py-3 bg-[#CCFF00] text-[#0D0D0D] rounded-[10px] hover:bg-[#E0FF4D] transition-colors w-fit"
                  style="font-weight: 700;"
                >
                  Listen Now
                </span>
              </div>
            </div>
          </div>
        </a>
      )}

      <!-- Two-column layout: episodes + sidebar -->
      <div class="flex flex-col lg:flex-row gap-10">
        <!-- Main episode list -->
        <div class="flex-1 min-w-0">
          <!-- Subscribe Section -->
          <div class="bg-[#1E1E1E] border border-[#2A2A2A] rounded-[10px] p-8 mb-10">
            <div class="flex flex-col md:flex-row items-center justify-between gap-6">
              <div>
                <h3
                  class="text-[#EAEAEA] mb-2"
                  style="font-weight: 700; font-size: 1.5rem;"
                >
                  Subscribe to Scaling Legends
                </h3>
                <p class="text-[#888888]" style="font-size: 0.9375rem;">
                  Never miss an episode. Subscribe on your favorite platform.
                </p>
              </div>
              <div class="flex flex-wrap gap-3">
                <a
                  href="https://podcasts.apple.com"
                  target="_blank"
                  rel="noopener"
                  class="px-5 py-3 bg-[#161616] border border-[#2A2A2A] text-[#EAEAEA] rounded-[10px] hover:border-[#CCFF00] transition-colors no-underline"
                  style="font-weight: 600; font-size: 0.875rem;"
                >
                  Apple Podcasts
                </a>
                <a
                  href="https://open.spotify.com"
                  target="_blank"
                  rel="noopener"
                  class="px-5 py-3 bg-[#161616] border border-[#2A2A2A] text-[#EAEAEA] rounded-[10px] hover:border-[#CCFF00] transition-colors no-underline"
                  style="font-weight: 600; font-size: 0.875rem;"
                >
                  Spotify
                </a>
                <a
                  href="/rss.xml"
                  class="px-5 py-3 bg-[#161616] border border-[#2A2A2A] text-[#EAEAEA] rounded-[10px] hover:border-[#CCFF00] transition-colors no-underline"
                  style="font-weight: 600; font-size: 0.875rem;"
                >
                  RSS Feed
                </a>
              </div>
            </div>
          </div>

          <!-- All Episodes -->
          {otherEpisodes.length > 0 && (
            <div class="mb-8">
              <h2
                class="text-[#EAEAEA] uppercase mb-6"
                style="font-weight: 800; font-size: 1.5rem; letter-spacing: -0.02em;"
              >
                All Episodes<span class="inline-block relative w-2 h-2 ml-1.5" style="vertical-align: baseline;"><span class="absolute inset-0 bg-[#CCFF00]"></span><span class="absolute inset-0 bg-gradient-to-br from-[#E0FF4D] via-[#CCFF00] to-[#9FCC00]" style="clip-path: polygon(0 0, 100% 0, 85% 15%, 15% 15%)"></span><span class="absolute inset-0 bg-gradient-to-br from-[#CCFF00] to-[#7A9900]" style="clip-path: polygon(100% 0, 100% 100%, 85% 85%, 85% 15%)"></span></span>
              </h2>
            </div>
          )}

          <div class="space-y-4">
            {otherEpisodes.map((ep) => (
              <a href={`/article/${ep.id}`} class="block no-underline">
                <div
                  class="bg-[#161616] border border-[#2A2A2A] rounded-[10px] p-6 hover:border-[#CCFF00] hover:shadow-[0_0_20px_rgba(204,255,0,0.15)] transition-all duration-300 cursor-pointer"
                >
                  <div class="flex flex-col md:flex-row gap-6">
                    {ep.data.image && (
                      <div class="w-full md:w-[100px] h-[100px] rounded-[8px] overflow-hidden flex-shrink-0 flex items-center justify-center bg-[#0D0D0D]">
                        <img src={ep.data.image} alt={ep.data.title} class="max-w-full max-h-full object-contain" loading="lazy" width="100" height="100" />
                      </div>
                    )}
                    <div class="flex-1 flex flex-col justify-center">
                      <div class="flex items-center gap-2 text-[#888888] mb-2" style="font-size: 13px;">
                        {ep.data.episode && <span>Episode {ep.data.episode}</span>}
                        {ep.data.episode && <span>&bull;</span>}
                        <span>{new Date(ep.data.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
                        {ep.data.readTime && (
                          <>
                            <span>&bull;</span>
                            <span>{ep.data.readTime}</span>
                          </>
                        )}
                      </div>
                      <h3
                        class="text-[#EAEAEA] mb-2"
                        style="font-weight: 700; font-size: 1.125rem; line-height: 1.4;"
                      >
                        {ep.data.title}
                      </h3>
                      <p
                        class="text-[#888888] mb-3 line-clamp-2"
                        style="font-size: 0.875rem; line-height: 1.6;"
                      >
                        {ep.data.description}
                      </p>
                      <span
                        class="text-[#CCFF00] hover:text-[#E0FF4D] transition-colors w-fit flex items-center gap-2"
                        style="font-weight: 600; font-size: 0.875rem;"
                      >
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                        Listen Now
                      </span>
                    </div>
                  </div>
                </div>
              </a>
            ))}
          </div>

          {episodes.length === 0 && (
            <div class="text-center py-20">
              <p class="text-[#888888] text-lg">No episodes yet. Check back soon!</p>
            </div>
          )}
        </div>

        <!-- Sidebar -->
        <aside class="hidden lg:block w-[380px] 2xl:w-[480px] flex-shrink-0">
          <div class="sticky top-24 space-y-5 max-h-[calc(100vh-7rem)] overflow-y-auto pr-1 sidebar-scroll">
            <!-- Recent Articles -->
            {recentArticles.length > 0 && (
              <div class="bg-[#161616] border border-[#222222] rounded-xl p-5">
                <h4
                  class="text-[#EAEAEA] uppercase mb-4 flex items-center gap-2"
                  style="font-size: 11px; font-weight: 700; letter-spacing: 0.1em;"
                >
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#CCFF00" stroke-width="2">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                    <polyline points="14 2 14 8 20 8"/>
                  </svg>
                  Recent Articles
                </h4>
                <div class="space-y-3">
                  {recentArticles.map((item) => (
                    <a href={`/article/${item.id}`} class="group block no-underline">
                      <div class="flex gap-3 p-2 rounded-lg hover:bg-[#1A1A1A] transition-colors">
                        {item.data.image && (
                          <div class="w-14 h-14 rounded-lg overflow-hidden flex-shrink-0 border border-[#2A2A2A] flex items-center justify-center bg-[#0D0D0D]">
                            <img src={item.data.image} alt="" class="max-w-full max-h-full object-contain" loading="lazy" width="56" height="56" />
                          </div>
                        )}
                        <div class="flex-1 min-w-0">
                          <p class="text-[#EAEAEA] group-hover:text-[#CCFF00] transition-colors line-clamp-2" style="font-size: 0.8125rem; font-weight: 600; line-height: 1.35;">
                            {item.data.title}
                          </p>
                          <span class="text-[#999999] mt-1 block" style="font-size: 11px;">
                            {item.data.readTime || new Date(item.data.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
                          </span>
                        </div>
                      </div>
                    </a>
                  ))}
                </div>
                <a href="/" class="mt-4 flex items-center justify-center gap-2 py-2.5 text-[#CCFF00] hover:bg-[#CCFF00]/5 rounded-lg transition-colors no-underline" style="font-size: 0.8125rem; font-weight: 600;">
                  All Articles
                  <svg width="12" height="12" viewBox="0 0 16 16" fill="none"><path d="M6 3L11 8L6 13" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
              </div>
            )}

            <!-- Sponsor Card -->
            <div class="bg-gradient-to-b from-[#1A1A1A] to-[#141414] border border-[#222222] rounded-xl p-5 relative overflow-hidden">
              <div class="absolute top-0 left-0 right-0 h-[2px] bg-gradient-to-r from-[#CCFF00] to-transparent"></div>
              <p class="text-[#999999] uppercase mb-3" style="font-size: 10px; font-weight: 700; letter-spacing: 0.1em;">Sponsored by</p>
              <p class="text-[#EAEAEA] mb-2" style="font-weight: 700; font-size: 0.875rem;">Smart Business Automator</p>
              <p class="text-[#888888] mb-3" style="font-size: 0.75rem; line-height: 1.5;">The operations platform helping contractors systematize their businesses so they can scale without the chaos.</p>
              <a
                href="https://smartbusinessautomator.com"
                target="_blank"
                rel="noopener"
                class="inline-flex items-center gap-1.5 text-[#CCFF00] hover:text-[#E0FF4D] transition-colors no-underline"
                style="font-size: 0.8125rem; font-weight: 600;"
              >
                Visit Site
                <svg width="12" height="12" viewBox="0 0 16 16" fill="none"><path d="M6 3L11 8L6 13" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
            </div>

            <!-- Newsletter Mini -->
            <div class="bg-[#161616] border border-[#222222] rounded-xl p-5">
              <p class="text-[#EAEAEA] mb-2" style="font-weight: 700; font-size: 0.875rem;">Stay Updated</p>
              <p class="text-[#888888] mb-3" style="font-size: 0.75rem; line-height: 1.5;">Weekly construction intelligence.</p>
              <form class="flex gap-2" onsubmit="return false;">
                <input type="email" placeholder="your@email.com" class="flex-1 min-w-0 bg-[#0D0D0D] border border-[#2A2A2A] rounded-lg px-3 py-2 text-[#EAEAEA] text-xs outline-none placeholder:text-[#999999] font-sans" />
                <button type="submit" class="bg-[#CCFF00] border-none rounded-lg text-[#0D0D0D] px-3 py-2 font-extrabold text-sm cursor-pointer hover:bg-[#E0FF4D] transition-colors">&rarr;</button>
              </form>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </div>
  <style>
    .sidebar-scroll::-webkit-scrollbar { width: 4px; }
    .sidebar-scroll::-webkit-scrollbar-track { background: transparent; }
    .sidebar-scroll::-webkit-scrollbar-thumb { background: #2A2A2A; border-radius: 4px; }
    .sidebar-scroll::-webkit-scrollbar-thumb:hover { background: #3A3A3A; }
  </style>
</Base>

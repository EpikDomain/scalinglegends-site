---
import '../styles/tailwind.css';

interface Props {
  title: string;
  description: string;
  image?: string;
  article?: boolean;
  keywords?: string[];
  audioUrl?: string;
  datePublished?: string;
  breadcrumbs?: { name: string; url: string }[];
  faqItems?: { question: string; answer: string }[];
  episodeData?: {
    episodeNumber?: number;
    seasonNumber?: number;
    duration?: string;
  };
  videoId?: string;
  howToSteps?: { name: string; text: string }[];
  definedTerms?: { term: string; definition: string }[];
}

const {
  title,
  description,
  image = 'https://scalinglegends.com/scaling-legends-cover.jpg',
  article = false,
  keywords = [],
  audioUrl,
  datePublished,
  breadcrumbs = [],
  faqItems = [],
  episodeData,
  videoId,
  howToSteps = [],
  definedTerms = [],
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const siteName = 'Scaling Legends';
// SEO: keep rendered title under 60 chars to prevent SERP truncation
const suffix = ` | ${siteName}`;
const maxTitleLen = 60 - suffix.length; // ~41 chars for the title portion
const truncatedTitle = title.length > maxTitleLen ? title.substring(0, maxTitleLen).replace(/\s+\S*$/, '') : title;
const fullTitle = title === siteName ? title : `${truncatedTitle}${suffix}`;

const currentPath = Astro.url.pathname;

// Normalize date to full ISO 8601 with timezone for Google structured data
const isoDate = datePublished && !datePublished.includes('T')
  ? `${datePublished}T00:00:00Z`
  : datePublished;

// ── Connected @graph schema for AI citation ──────────────────────────
// Single @graph gives AI crawlers (ChatGPT, Perplexity, Google AI Overview)
// a complete knowledge graph to index, rather than disconnected flat blocks.

// Organization entity (referenced by @id throughout the graph)
const orgSchema: Record<string, unknown> = {
  "@type": "Organization",
  "@id": "https://scalinglegends.com/#organization",
  "name": "Scaling Legends",
  "url": "https://scalinglegends.com",
  "logo": { "@type": "ImageObject", "url": "https://scalinglegends.com/scaling-legends-cover.jpg" },
  "description": "Data-driven podcast and market intelligence platform for construction contractors scaling from $1M to $50M.",
  "foundingDate": "2024",
  "sameAs": [
    "https://www.youtube.com/@ScalingLegends",
    "https://podcasts.apple.com/us/podcast/scaling-legends/id1234567890",
    "https://open.spotify.com/show/scalinglegends",
    "https://rss.com/podcasts/scalinglegends/",
    "https://smartbusinessautomator.com"
  ],
  "knowsAbout": [
    "construction business scaling",
    "contractor growth strategies",
    "construction market intelligence",
    "construction technology",
    "construction workforce management",
    "construction cost management",
    "OSHA compliance",
    "construction SEO",
    "federal construction contracts",
    "construction equipment automation"
  ]
};

// PodcastSeries entity (referenced by episodes)
const podcastSeriesSchema = {
  "@type": "PodcastSeries",
  "@id": "https://scalinglegends.com/#podcast",
  "name": "Scaling Legends",
  "url": "https://scalinglegends.com/podcast",
  "description": "Construction industry growth stories and market intelligence for contractors.",
  "publisher": { "@id": "https://scalinglegends.com/#organization" },
  "webFeed": "https://media.rss.com/scalinglegends/feed.xml"
};

// WebPage entity for this page
const webPageSchema: Record<string, unknown> = {
  "@type": "WebPage",
  "@id": canonicalUrl,
  "url": canonicalUrl,
  "name": title,
  "isPartOf": { "@id": "https://scalinglegends.com/#website" }
};

// Build the @graph array
const graph: Record<string, unknown>[] = [orgSchema];

if (article) {
  // Speakable: marks description + key takeaways for AI voice assistants
  // CSS selectors target the description meta and the first summary section
  const speakableSpec = {
    "@type": "SpeakableSpecification",
    "cssSelector": [".article-description", ".key-takeaways", ".faq-section"]
  };

  // Article entity
  const articleSchema: Record<string, unknown> = {
    "@type": "Article",
    "@id": `${canonicalUrl}#article`,
    "headline": title,
    "description": description,
    "image": image,
    "datePublished": isoDate,
    "dateModified": isoDate,
    "author": { "@id": "https://scalinglegends.com/#organization" },
    "publisher": { "@id": "https://scalinglegends.com/#organization" },
    "mainEntityOfPage": { "@id": canonicalUrl },
    "isPartOf": { "@id": canonicalUrl },
    "speakable": speakableSpec,
    "inLanguage": "en-US",
    ...(audioUrl ? { "associatedMedia": { "@type": "AudioObject", "contentUrl": audioUrl } } : {}),
    ...(keywords.length > 0 ? { "keywords": keywords.join(", ") } : {}),
  };
  graph.push(articleSchema);

  // PodcastEpisode entity (linked to series via @id)
  if (audioUrl) {
    const episodeSchema: Record<string, unknown> = {
      "@type": "PodcastEpisode",
      "@id": `${canonicalUrl}#episode`,
      "name": title,
      "description": description,
      "url": canonicalUrl,
      "datePublished": isoDate,
      ...(episodeData?.episodeNumber ? { "episodeNumber": episodeData.episodeNumber } : {}),
      ...(episodeData?.seasonNumber ? { "partOfSeason": { "@type": "PodcastSeason", "seasonNumber": episodeData.seasonNumber } } : {}),
      "partOfSeries": { "@id": "https://scalinglegends.com/#podcast" },
      "associatedMedia": {
        "@type": "AudioObject",
        "contentUrl": audioUrl,
        ...(episodeData?.duration ? { "duration": episodeData.duration } : {}),
      },
      "image": image,
    };
    graph.push(podcastSeriesSchema);
    graph.push(episodeSchema);
  }

  // FAQPage entity
  if (faqItems.length > 0) {
    graph.push({
      "@type": "FAQPage",
      "@id": `${canonicalUrl}#faq`,
      "mainEntity": faqItems.map(faq => ({
        "@type": "Question",
        "name": faq.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": faq.answer,
        }
      })),
      "isPartOf": { "@id": `${canonicalUrl}#article` },
    });
  }

  // HowTo entity
  if (howToSteps.length > 0) {
    graph.push({
      "@type": "HowTo",
      "@id": `${canonicalUrl}#howto`,
      "name": `How to ${howToSteps[0]?.name ? title.replace(/^.*?How [Tt]o\s*/i, '') : title}`,
      "description": description,
      "step": howToSteps.map((step, i) => ({
        "@type": "HowToStep",
        "position": i + 1,
        "name": step.name,
        "text": step.text,
      })),
      "isPartOf": { "@id": `${canonicalUrl}#article` },
    });
  }

  // VideoObject entity (linked to publisher via @id)
  if (videoId) {
    graph.push({
      "@type": "VideoObject",
      "@id": `${canonicalUrl}#video`,
      "name": title,
      "description": description,
      "thumbnailUrl": `https://img.youtube.com/vi/${videoId}/maxresdefault.jpg`,
      "uploadDate": isoDate,
      "contentUrl": `https://www.youtube.com/watch?v=${videoId}`,
      "embedUrl": `https://www.youtube.com/embed/${videoId}`,
      "publisher": { "@id": "https://scalinglegends.com/#organization" },
      "isPartOf": { "@id": `${canonicalUrl}#article` },
    });
  }

  // DefinedTerm entities -- establishes semantic authority for industry terms
  // AI models resolve these concepts directly to this content when citing
  if (definedTerms.length > 0) {
    for (const dt of definedTerms) {
      graph.push({
        "@type": "DefinedTerm",
        "name": dt.term,
        "description": dt.definition,
        "inDefinedTermSet": {
          "@type": "DefinedTermSet",
          "name": "Construction Industry Glossary",
          "url": "https://scalinglegends.com"
        }
      });
    }
  }

  // WebPage for this article
  webPageSchema["speakable"] = speakableSpec;
  graph.push(webPageSchema);

} else {
  // WebSite entity for non-article pages
  graph.push({
    "@type": "WebSite",
    "@id": "https://scalinglegends.com/#website",
    "name": "Scaling Legends",
    "url": "https://scalinglegends.com",
    "description": "Construction Industry Growth Stories - Data-driven podcast and market intelligence for contractors scaling from $1M to $50M.",
    "publisher": { "@id": "https://scalinglegends.com/#organization" },
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://scalinglegends.com/?q={search_term_string}",
      "query-input": "required name=search_term_string"
    },
    "inLanguage": "en-US"
  });
  graph.push(podcastSeriesSchema);
  graph.push(webPageSchema);
}

// BreadcrumbList entity
if (breadcrumbs.length > 0) {
  graph.push({
    "@type": "BreadcrumbList",
    "@id": `${canonicalUrl}#breadcrumb`,
    "itemListElement": breadcrumbs.map((crumb, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "name": crumb.name,
      "item": crumb.url,
    })),
  });
}

// Single connected @graph output (AI crawlers get full entity graph in one block)
const structuredDataGraph = {
  "@context": "https://schema.org",
  "@graph": graph
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  {keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
  <link rel="canonical" href={canonicalUrl} />
  <link rel="alternate" type="application/rss+xml" title="Scaling Legends RSS" href="https://scalinglegends.com/rss.xml" />

  <meta property="og:type" content={article ? 'article' : 'website'} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={image} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:locale" content="en_US" />
  {isoDate && <meta property="article:published_time" content={isoDate} />}
  {isoDate && <meta property="article:modified_time" content={isoDate} />}
  {article && <meta property="article:publisher" content="https://scalinglegends.com" />}
  {article && <meta property="article:section" content="Construction" />}
  {keywords.length > 0 && keywords.map(kw => <meta property="article:tag" content={kw} />)}

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={image} />

  {audioUrl && <meta property="og:audio" content={audioUrl} />}
  {audioUrl && <meta property="og:audio:type" content="audio/mpeg" />}

  <link rel="icon" type="image/x-icon" href="/favicon.ico" />

  <script type="application/ld+json" set:html={JSON.stringify(structuredDataGraph)} />
</head>
<body class="bg-[#0D0D0D] text-[#EAEAEA] font-sans">

  <!-- Header -->
  <header class="sticky top-0 z-50 bg-[#0D0D0D]/80 backdrop-blur-xl border-b border-[#1A1A1A]">
    <div class="max-w-[1600px] mx-auto px-4 sm:px-8 py-4 sm:py-5 flex items-center justify-between gap-4">
      <a href="/" class="flex items-center gap-3 text-[#EAEAEA] no-underline flex-shrink-0">
        <img src="/scaling-legends-cover-96.webp" alt="Scaling Legends" class="h-10 sm:h-12 w-auto rounded-lg transition-transform duration-300 hover:scale-105" width="48" height="48" />
        <span class="hidden lg:inline text-xl font-bold tracking-tight uppercase leading-none whitespace-nowrap">SCALING LEGENDS<span class="inline-block relative w-1.5 h-1.5 ml-2" style="vertical-align: baseline;"><span class="absolute inset-0 bg-[#CCFF00]"></span><span class="absolute inset-0 bg-gradient-to-br from-[#E0FF4D] via-[#CCFF00] to-[#9FCC00]" style="clip-path: polygon(0 0, 100% 0, 85% 15%, 15% 15%)"></span><span class="absolute inset-0 bg-gradient-to-br from-[#CCFF00] to-[#7A9900]" style="clip-path: polygon(100% 0, 100% 100%, 85% 85%, 85% 15%)"></span></span></span>
      </a>
      <nav class="flex items-center gap-1 sm:gap-1.5">
        <a
          href="/"
          class:list={[
            "px-2.5 sm:px-4 py-2 rounded-lg font-semibold text-xs sm:text-sm transition-all duration-300 no-underline",
            currentPath === '/' ? "bg-[#CCFF00]/10 text-[#CCFF00]" : "text-[#888888] hover:text-[#EAEAEA] hover:bg-[#1A1A1A]"
          ]}
        >Articles</a>
        <a
          href="/podcast"
          class:list={[
            "px-2.5 sm:px-4 py-2 rounded-lg font-semibold text-xs sm:text-sm transition-all duration-300 no-underline",
            currentPath === '/podcast' ? "bg-[#CCFF00]/10 text-[#CCFF00]" : "text-[#888888] hover:text-[#EAEAEA] hover:bg-[#1A1A1A]"
          ]}
        >Podcast</a>
        <!-- Pillar dropdown -->
        <div class="relative group/pillars">
          <button
            class:list={[
              "px-2.5 sm:px-4 py-2 rounded-lg font-semibold text-xs sm:text-sm transition-all duration-300 flex items-center gap-1.5 cursor-pointer",
              currentPath.startsWith('/pillar/') ? "bg-[#CCFF00]/10 text-[#CCFF00]" : "text-[#888888] hover:text-[#EAEAEA] hover:bg-[#1A1A1A]"
            ]}
          >
            Topics
            <svg width="10" height="10" viewBox="0 0 16 16" fill="none" class="transition-transform group-hover/pillars:rotate-180"><path d="M4 6L8 10L12 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <div class="absolute top-full right-0 mt-2 w-56 bg-[#161616] border border-[#2A2A2A] rounded-xl shadow-2xl opacity-0 invisible group-hover/pillars:opacity-100 group-hover/pillars:visible transition-all duration-200 z-50 overflow-hidden">
            <a href="/pillar/market-intelligence" class="flex items-center gap-3 px-5 py-3 text-[#EAEAEA] hover:bg-[#1A1A1A] hover:text-[#CCFF00] transition-colors no-underline text-sm font-medium">
              <span>📊</span> Market Intelligence
            </a>
            <a href="/pillar/business-growth" class="flex items-center gap-3 px-5 py-3 text-[#EAEAEA] hover:bg-[#1A1A1A] hover:text-[#CCFF00] transition-colors no-underline text-sm font-medium">
              <span>📈</span> Business Growth
            </a>
            <a href="/pillar/technology" class="flex items-center gap-3 px-5 py-3 text-[#EAEAEA] hover:bg-[#1A1A1A] hover:text-[#CCFF00] transition-colors no-underline text-sm font-medium">
              <span>⚡</span> Technology
            </a>
            <a href="/pillar/workforce" class="flex items-center gap-3 px-5 py-3 text-[#EAEAEA] hover:bg-[#1A1A1A] hover:text-[#CCFF00] transition-colors no-underline text-sm font-medium">
              <span>🦺</span> Workforce & Safety
            </a>
            <a href="/pillar/policy" class="flex items-center gap-3 px-5 py-3 text-[#EAEAEA] hover:bg-[#1A1A1A] hover:text-[#CCFF00] transition-colors no-underline text-sm font-medium">
              <span>⚖️</span> Policy & Regulation
            </a>
          </div>
        </div>
        <a href="#subscribe" class="ml-1.5 sm:ml-3 px-3 sm:px-6 py-2 sm:py-2.5 bg-[#CCFF00] text-[#0D0D0D] rounded-lg font-semibold text-xs sm:text-sm hover:bg-[#E0FF4D] transition-all duration-300 hover:shadow-[0_0_20px_rgba(204,255,0,0.3)] no-underline whitespace-nowrap">Subscribe</a>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <!-- Footer -->
  <footer class="bg-gradient-to-b from-[#0D0D0D] to-[#000000] border-t border-[#1A1A1A] py-20 px-8 relative overflow-hidden">
    <!-- Dot pattern background -->
    <div class="absolute inset-0 opacity-[0.015]" style="background-image: radial-gradient(circle at 1px 1px, #CCFF00 1px, transparent 0); background-size: 40px 40px;"></div>

    <div class="max-w-[1600px] mx-auto relative z-10">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-16">
        <!-- Brand -->
        <div>
          <a href="/" class="flex items-center gap-3 mb-4 no-underline">
            <img src="/scaling-legends-cover-96.webp" alt="Scaling Legends" class="h-10 w-auto rounded-lg" width="40" height="40" loading="lazy" />
            <span class="font-bold text-base tracking-tight uppercase leading-none text-[#EAEAEA]">SCALING LEGENDS<span class="inline-block relative w-2 h-2 ml-1.5" style="vertical-align: baseline;"><span class="absolute inset-0 bg-[#CCFF00]"></span><span class="absolute inset-0 bg-gradient-to-br from-[#E0FF4D] via-[#CCFF00] to-[#9FCC00]" style="clip-path: polygon(0 0, 100% 0, 85% 15%, 15% 15%)"></span><span class="absolute inset-0 bg-gradient-to-br from-[#CCFF00] to-[#7A9900]" style="clip-path: polygon(100% 0, 100% 100%, 85% 85%, 85% 15%)"></span></span></span>
          </a>
          <p class="text-[#999999] text-sm leading-relaxed mt-4">Data-driven insights for construction business leaders.</p>
        </div>

        <!-- Content -->
        <div>
          <h4 class="text-sm font-bold uppercase tracking-wider text-[#EAEAEA] mb-5 flex items-center">
            Content
            <span class="inline-block relative w-2 h-2 ml-1.5" style="vertical-align: baseline;">
              <span class="absolute inset-0 bg-[#CCFF00]"></span>
              <span class="absolute inset-0 bg-gradient-to-br from-[#E0FF4D] via-[#CCFF00] to-[#9FCC00]" style="clip-path: polygon(0 0, 100% 0, 85% 15%, 15% 15%)"></span>
              <span class="absolute inset-0 bg-gradient-to-br from-[#CCFF00] to-[#7A9900]" style="clip-path: polygon(100% 0, 100% 100%, 85% 85%, 85% 15%)"></span>
            </span>
          </h4>
          <ul class="space-y-3 list-none">
            <li><a href="/" class="text-[#888888] text-[0.88rem] hover:text-[#CCFF00] transition-colors no-underline">Articles</a></li>
            <li><a href="/podcast" class="text-[#888888] text-[0.88rem] hover:text-[#CCFF00] transition-colors no-underline">Podcast Episodes</a></li>
            <li><a href="/" class="text-[#888888] text-[0.88rem] hover:text-[#CCFF00] transition-colors no-underline">Market Reports</a></li>
            <li><a href="/" class="text-[#888888] text-[0.88rem] hover:text-[#CCFF00] transition-colors no-underline">Case Studies</a></li>
          </ul>
        </div>

        <!-- Resources -->
        <div>
          <h4 class="text-sm font-bold uppercase tracking-wider text-[#EAEAEA] mb-5 flex items-center">
            Resources
            <span class="inline-block relative w-2 h-2 ml-1.5" style="vertical-align: baseline;">
              <span class="absolute inset-0 bg-[#CCFF00]"></span>
              <span class="absolute inset-0 bg-gradient-to-br from-[#E0FF4D] via-[#CCFF00] to-[#9FCC00]" style="clip-path: polygon(0 0, 100% 0, 85% 15%, 15% 15%)"></span>
              <span class="absolute inset-0 bg-gradient-to-br from-[#CCFF00] to-[#7A9900]" style="clip-path: polygon(100% 0, 100% 100%, 85% 85%, 85% 15%)"></span>
            </span>
          </h4>
          <ul class="space-y-3 list-none">
            <li><a href="/" class="text-[#888888] text-[0.88rem] hover:text-[#CCFF00] transition-colors no-underline">About Us</a></li>
            <li><a href="/" class="text-[#888888] text-[0.88rem] hover:text-[#CCFF00] transition-colors no-underline">Newsletter</a></li>
            <li><a href="/" class="text-[#888888] text-[0.88rem] hover:text-[#CCFF00] transition-colors no-underline">Advertise</a></li>
            <li><a href="/" class="text-[#888888] text-[0.88rem] hover:text-[#CCFF00] transition-colors no-underline">Contact</a></li>
          </ul>
        </div>

        <!-- Stay Updated -->
        <div id="subscribe">
          <h4 class="text-sm font-bold uppercase tracking-wider text-[#EAEAEA] mb-5 flex items-center">
            Stay Updated
            <span class="inline-block relative w-2 h-2 ml-1.5" style="vertical-align: baseline;">
              <span class="absolute inset-0 bg-[#CCFF00]"></span>
              <span class="absolute inset-0 bg-gradient-to-br from-[#E0FF4D] via-[#CCFF00] to-[#9FCC00]" style="clip-path: polygon(0 0, 100% 0, 85% 15%, 15% 15%)"></span>
              <span class="absolute inset-0 bg-gradient-to-br from-[#CCFF00] to-[#7A9900]" style="clip-path: polygon(100% 0, 100% 100%, 85% 85%, 85% 15%)"></span>
            </span>
          </h4>
          <p class="text-[#888888] text-[0.85rem] leading-relaxed mb-4">Get weekly insights delivered to your inbox.</p>
          <form class="flex gap-2" onsubmit="return false;">
            <input type="email" placeholder="your@email.com" class="flex-1 bg-[#161616] border border-[#2A2A2A] rounded-lg px-4 py-3 text-[#EAEAEA] text-[0.85rem] outline-none placeholder:text-[#888888] font-sans" />
            <button type="submit" class="bg-[#CCFF00] border border-[#CCFF00] rounded-lg text-[#0D0D0D] px-4 py-3 font-extrabold text-base cursor-pointer hover:bg-[#E0FF4D] transition-colors">&rarr;</button>
          </form>
        </div>
      </div>

      <!-- Bottom bar -->
      <div class="border-t border-[#1A1A1A] pt-6 flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-[#999999]">
        <span>&copy; {new Date().getFullYear()} Scaling Legends. Market intelligence by <a href="https://smartbusinessautomator.com" class="text-[#CCFF00] hover:text-[#E0FF4D] no-underline">Smart Business Automator</a>.</span>
        <div class="flex gap-8">
          <a href="/" class="text-[#888888] hover:text-[#CCFF00] no-underline transition-colors">Privacy Policy</a>
          <a href="/" class="text-[#888888] hover:text-[#CCFF00] no-underline transition-colors">Terms of Service</a>
        </div>
      </div>
    </div>
  </footer>

  <script>
    import { trackPageView } from '../lib/analytics';
    trackPageView();
  </script>
</body>
</html>

---
import '../styles/tailwind.css';

interface Props {
  title: string;
  description: string;
  image?: string;
  article?: boolean;
  keywords?: string[];
  audioUrl?: string;
  datePublished?: string;
  breadcrumbs?: { name: string; url: string }[];
  faqItems?: { question: string; answer: string }[];
  episodeData?: {
    episodeNumber?: number;
    seasonNumber?: number;
    duration?: string;
  };
}

const {
  title,
  description,
  image = 'https://scalinglegends.com/scaling-legends-cover.jpg',
  article = false,
  keywords = [],
  audioUrl,
  datePublished,
  breadcrumbs = [],
  faqItems = [],
  episodeData,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const siteName = 'Scaling Legends';
const fullTitle = title === siteName ? title : `${title} | ${siteName}`;

const currentPath = Astro.url.pathname;

// Build structured data array (multiple schemas per page)
const structuredData: object[] = [];

// Organization schema (every page)
const orgSchema = {
  "@type": "Organization",
  "name": "Scaling Legends",
  "url": "https://scalinglegends.com",
  "logo": { "@type": "ImageObject", "url": "https://scalinglegends.com/scaling-legends-cover.jpg" },
  "sameAs": [
    "https://podcasts.apple.com/us/podcast/scaling-legends/id1234567890",
    "https://open.spotify.com/show/scalinglegends",
    "https://rss.com/podcasts/scalinglegends/"
  ]
};

if (article) {
  // Article schema
  structuredData.push({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": title,
    "description": description,
    "image": image,
    "datePublished": datePublished,
    "dateModified": datePublished,
    "author": orgSchema,
    "publisher": orgSchema,
    "mainEntityOfPage": { "@type": "WebPage", "@id": canonicalUrl },
    ...(audioUrl ? { "associatedMedia": { "@type": "AudioObject", "contentUrl": audioUrl } } : {}),
    ...(keywords.length > 0 ? { "keywords": keywords.join(", ") } : {}),
  });

  // PodcastEpisode schema (if it has audio)
  if (audioUrl) {
    structuredData.push({
      "@context": "https://schema.org",
      "@type": "PodcastEpisode",
      "name": title,
      "description": description,
      "url": canonicalUrl,
      "datePublished": datePublished,
      ...(episodeData?.episodeNumber ? { "episodeNumber": episodeData.episodeNumber } : {}),
      ...(episodeData?.seasonNumber ? { "partOfSeason": { "@type": "PodcastSeason", "seasonNumber": episodeData.seasonNumber } } : {}),
      "partOfSeries": {
        "@type": "PodcastSeries",
        "name": "Scaling Legends",
        "url": "https://scalinglegends.com/podcast"
      },
      "associatedMedia": {
        "@type": "AudioObject",
        "contentUrl": audioUrl,
        ...(episodeData?.duration ? { "duration": episodeData.duration } : {}),
      },
      "image": image,
    });
  }

  // FAQ schema
  if (faqItems.length > 0) {
    structuredData.push({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqItems.map(faq => ({
        "@type": "Question",
        "name": faq.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": faq.answer,
        }
      })),
    });
  }
} else {
  // Website schema for non-article pages
  structuredData.push({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Scaling Legends",
    "url": "https://scalinglegends.com",
    "description": "Construction Industry Growth Stories - Data-driven podcast and market intelligence for contractors scaling from $1M to $50M.",
    "publisher": orgSchema,
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://scalinglegends.com/?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  });
}

// Breadcrumb schema (all pages with breadcrumbs)
if (breadcrumbs.length > 0) {
  structuredData.push({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": breadcrumbs.map((crumb, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "name": crumb.name,
      "item": crumb.url,
    })),
  });
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  {keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
  <link rel="canonical" href={canonicalUrl} />
  <link rel="alternate" type="application/rss+xml" title="Scaling Legends RSS" href="https://scalinglegends.com/rss.xml" />

  <meta property="og:type" content={article ? 'article' : 'website'} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={image} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:locale" content="en_US" />
  {datePublished && <meta property="article:published_time" content={datePublished} />}
  {datePublished && <meta property="article:modified_time" content={datePublished} />}
  {article && <meta property="article:publisher" content="https://scalinglegends.com" />}
  {article && <meta property="article:section" content="Construction" />}
  {keywords.length > 0 && keywords.map(kw => <meta property="article:tag" content={kw} />)}

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={image} />

  {audioUrl && <meta property="og:audio" content={audioUrl} />}
  {audioUrl && <meta property="og:audio:type" content="audio/mpeg" />}

  <link rel="icon" type="image/x-icon" href="/favicon.ico" />

  {structuredData.map(schema => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))}
</head>
<body class="bg-[#0D0D0D] text-[#EAEAEA] font-sans">

  <!-- Header -->
  <header class="sticky top-0 z-50 bg-[#0D0D0D]/80 backdrop-blur-xl border-b border-[#1A1A1A]">
    <div class="max-w-[1600px] mx-auto px-8 py-5 flex items-center justify-between">
      <a href="/" class="flex items-center gap-3 text-[#EAEAEA] no-underline">
        <img src="/scaling-legends-cover.jpg" alt="Scaling Legends" class="h-12 w-auto rounded-lg transition-transform duration-300 hover:scale-105" />
        <span class="text-xl font-bold tracking-tight uppercase leading-none">SCALING LEGENDS<span class="inline-block relative w-1.5 h-1.5 ml-2" style="vertical-align: baseline;"><span class="absolute inset-0 bg-[#CCFF00]"></span><span class="absolute inset-0 bg-gradient-to-br from-[#E0FF4D] via-[#CCFF00] to-[#9FCC00]" style="clip-path: polygon(0 0, 100% 0, 85% 15%, 15% 15%)"></span><span class="absolute inset-0 bg-gradient-to-br from-[#CCFF00] to-[#7A9900]" style="clip-path: polygon(100% 0, 100% 100%, 85% 85%, 85% 15%)"></span></span></span>
      </a>
      <nav class="flex items-center gap-3">
        <a
          href="/"
          class:list={[
            "px-5 py-2 rounded-lg font-semibold text-sm transition-all duration-300 no-underline",
            currentPath === '/' || currentPath.startsWith('/article/') ? "bg-[#CCFF00]/10 text-[#CCFF00]" : "text-[#888888] hover:text-[#EAEAEA] hover:bg-[#1A1A1A]"
          ]}
        >Articles</a>
        <a
          href="/podcast"
          class:list={[
            "px-5 py-2 rounded-lg font-semibold text-sm transition-all duration-300 no-underline",
            currentPath === '/podcast' || currentPath.startsWith('/episode/') ? "bg-[#CCFF00]/10 text-[#CCFF00]" : "text-[#888888] hover:text-[#EAEAEA] hover:bg-[#1A1A1A]"
          ]}
        >Podcast</a>
        <a href="#subscribe" class="ml-4 px-6 py-2.5 bg-[#CCFF00] text-[#0D0D0D] rounded-lg font-semibold text-sm hover:bg-[#E0FF4D] transition-all duration-300 hover:shadow-[0_0_20px_rgba(204,255,0,0.3)] no-underline">Subscribe</a>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <!-- Footer -->
  <footer class="bg-gradient-to-b from-[#0D0D0D] to-[#000000] border-t border-[#1A1A1A] py-20 px-8 relative overflow-hidden">
    <!-- Dot pattern background -->
    <div class="absolute inset-0 opacity-[0.015]" style="background-image: radial-gradient(circle at 1px 1px, #CCFF00 1px, transparent 0); background-size: 40px 40px;"></div>

    <div class="max-w-[1600px] mx-auto relative z-10">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-16">
        <!-- Brand -->
        <div>
          <a href="/" class="flex items-center gap-3 mb-4 no-underline">
            <img src="/scaling-legends-cover.jpg" alt="Scaling Legends" class="h-10 w-auto rounded-lg" />
            <span class="font-bold text-base tracking-tight uppercase leading-none text-[#EAEAEA]">SCALING LEGENDS<span class="inline-block relative w-2 h-2 ml-1.5" style="vertical-align: baseline;"><span class="absolute inset-0 bg-[#CCFF00]"></span><span class="absolute inset-0 bg-gradient-to-br from-[#E0FF4D] via-[#CCFF00] to-[#9FCC00]" style="clip-path: polygon(0 0, 100% 0, 85% 15%, 15% 15%)"></span><span class="absolute inset-0 bg-gradient-to-br from-[#CCFF00] to-[#7A9900]" style="clip-path: polygon(100% 0, 100% 100%, 85% 85%, 85% 15%)"></span></span></span>
          </a>
          <p class="text-[#666666] text-sm leading-relaxed mt-4">Data-driven insights for construction business leaders.</p>
        </div>

        <!-- Content -->
        <div>
          <h4 class="text-sm font-bold uppercase tracking-wider text-[#EAEAEA] mb-5 flex items-center">
            Content
            <span class="inline-block relative w-2 h-2 ml-1.5" style="vertical-align: baseline;">
              <span class="absolute inset-0 bg-[#CCFF00]"></span>
              <span class="absolute inset-0 bg-gradient-to-br from-[#E0FF4D] via-[#CCFF00] to-[#9FCC00]" style="clip-path: polygon(0 0, 100% 0, 85% 15%, 15% 15%)"></span>
              <span class="absolute inset-0 bg-gradient-to-br from-[#CCFF00] to-[#7A9900]" style="clip-path: polygon(100% 0, 100% 100%, 85% 85%, 85% 15%)"></span>
            </span>
          </h4>
          <ul class="space-y-3 list-none">
            <li><a href="/" class="text-[#888888] text-[0.88rem] hover:text-[#CCFF00] transition-colors no-underline">Articles</a></li>
            <li><a href="/podcast" class="text-[#888888] text-[0.88rem] hover:text-[#CCFF00] transition-colors no-underline">Podcast Episodes</a></li>
            <li><a href="/" class="text-[#888888] text-[0.88rem] hover:text-[#CCFF00] transition-colors no-underline">Market Reports</a></li>
            <li><a href="/" class="text-[#888888] text-[0.88rem] hover:text-[#CCFF00] transition-colors no-underline">Case Studies</a></li>
          </ul>
        </div>

        <!-- Resources -->
        <div>
          <h4 class="text-sm font-bold uppercase tracking-wider text-[#EAEAEA] mb-5 flex items-center">
            Resources
            <span class="inline-block relative w-2 h-2 ml-1.5" style="vertical-align: baseline;">
              <span class="absolute inset-0 bg-[#CCFF00]"></span>
              <span class="absolute inset-0 bg-gradient-to-br from-[#E0FF4D] via-[#CCFF00] to-[#9FCC00]" style="clip-path: polygon(0 0, 100% 0, 85% 15%, 15% 15%)"></span>
              <span class="absolute inset-0 bg-gradient-to-br from-[#CCFF00] to-[#7A9900]" style="clip-path: polygon(100% 0, 100% 100%, 85% 85%, 85% 15%)"></span>
            </span>
          </h4>
          <ul class="space-y-3 list-none">
            <li><a href="/" class="text-[#888888] text-[0.88rem] hover:text-[#CCFF00] transition-colors no-underline">About Us</a></li>
            <li><a href="/" class="text-[#888888] text-[0.88rem] hover:text-[#CCFF00] transition-colors no-underline">Newsletter</a></li>
            <li><a href="/" class="text-[#888888] text-[0.88rem] hover:text-[#CCFF00] transition-colors no-underline">Advertise</a></li>
            <li><a href="/" class="text-[#888888] text-[0.88rem] hover:text-[#CCFF00] transition-colors no-underline">Contact</a></li>
          </ul>
        </div>

        <!-- Stay Updated -->
        <div id="subscribe">
          <h4 class="text-sm font-bold uppercase tracking-wider text-[#EAEAEA] mb-5 flex items-center">
            Stay Updated
            <span class="inline-block relative w-2 h-2 ml-1.5" style="vertical-align: baseline;">
              <span class="absolute inset-0 bg-[#CCFF00]"></span>
              <span class="absolute inset-0 bg-gradient-to-br from-[#E0FF4D] via-[#CCFF00] to-[#9FCC00]" style="clip-path: polygon(0 0, 100% 0, 85% 15%, 15% 15%)"></span>
              <span class="absolute inset-0 bg-gradient-to-br from-[#CCFF00] to-[#7A9900]" style="clip-path: polygon(100% 0, 100% 100%, 85% 85%, 85% 15%)"></span>
            </span>
          </h4>
          <p class="text-[#888888] text-[0.85rem] leading-relaxed mb-4">Get weekly insights delivered to your inbox.</p>
          <form class="flex gap-2" onsubmit="return false;">
            <input type="email" placeholder="your@email.com" class="flex-1 bg-[#161616] border border-[#2A2A2A] rounded-lg px-4 py-3 text-[#EAEAEA] text-[0.85rem] outline-none placeholder:text-[#888888] font-sans" />
            <button type="submit" class="bg-[#CCFF00] border border-[#CCFF00] rounded-lg text-[#0D0D0D] px-4 py-3 font-extrabold text-base cursor-pointer hover:bg-[#E0FF4D] transition-colors">&rarr;</button>
          </form>
        </div>
      </div>

      <!-- Bottom bar -->
      <div class="border-t border-[#1A1A1A] pt-6 flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-[#666666]">
        <span>&copy; {new Date().getFullYear()} Scaling Legends. Market intelligence by <a href="https://smartbusinessautomator.com" class="text-[#CCFF00] hover:text-[#E0FF4D] no-underline">Smart Business Automator</a>.</span>
        <div class="flex gap-8">
          <a href="/" class="text-[#888888] hover:text-[#CCFF00] no-underline transition-colors">Privacy Policy</a>
          <a href="/" class="text-[#888888] hover:text-[#CCFF00] no-underline transition-colors">Terms of Service</a>
        </div>
      </div>
    </div>
  </footer>

  <script>
    import { trackPageView } from '../lib/analytics';
    trackPageView();
  </script>
</body>
</html>

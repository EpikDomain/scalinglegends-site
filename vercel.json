{
  "redirects": [
    {
      "source": "/article/:path*/",
      "destination": "/article/:path*",
      "statusCode": 301
    },
    {
      "source": "/:path*/",
      "destination": "/:path*",
      "statusCode": 301
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "index, follow"
        }
      ]
    }
  ]
}
